# Runtime
NODE_ENV=production
PORT=3000

# AI providers
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash

# Admin auth
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_TTL_SECONDS=43200

# Anonymous session security
ANON_SESSION_SECRET=
COOKIE_SECURE=true
COOKIE_SAME_SITE=Lax
TRUST_PROXY=true
ANON_SESSION_IDLE_TTL_MS=1800000
ANON_SESSION_ABSOLUTE_TTL_MS=86400000
ANON_SESSION_COOLDOWN_MS=300000
SESSION_STORE_CLEANUP_INTERVAL_MS=60000
ANON_SESSION_FILE_PATH=
ANON_SESSION_TABLE=anonymous_sessions
ANON_SESSION_COOLDOWN_TABLE=anonymous_session_cooldowns
SESSION_REDIS_ENABLED=false
MAINTENANCE_MODE=false
MAINTENANCE_FLAG_FILE=
MAINTENANCE_RETRY_AFTER_SECONDS=120

# Session quotas
CHAT_SESSION_REQUEST_LIMIT=20
CHAT_SESSION_PHOTO_LIMIT=6
CHAT_FEEDBACK_SESSION_LIMIT=24

# Request limits (IP/window)
RATE_LIMIT_WINDOW_MS=60000
CHAT_OPTIONS_RATE_LIMIT_MAX=24
CHAT_PHOTO_RATE_LIMIT_MAX=10
CHAT_FEEDBACK_RATE_LIMIT_MAX=40
ADMIN_LOGIN_RATE_LIMIT_MAX=6
ADMIN_ROUTE_RATE_LIMIT_MAX=60

# Operational telemetry / alert thresholds
OPS_ALERT_WINDOW_MS=60000
OPS_ALERT_COOLDOWN_MS=30000
OPS_ALERT_HTTP_5XX_THRESHOLD=8
OPS_ALERT_HTTP_429_THRESHOLD=25
OPS_ALERT_BLOCKED_PROMPT_THRESHOLD=12
OPS_ALERT_SUSPICIOUS_UPLOAD_THRESHOLD=8
OPS_ALERT_READINESS_FAILURE_THRESHOLD=3
OPS_ALERT_AI_FAILURE_THRESHOLD=8
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_WEBHOOK_TIMEOUT_MS=4000

# Payload / AI transport
MAX_BODY_SIZE_BYTES=8388608
CHAT_PROMPT_MAX_CHARS=1500
CHAT_HISTORY_MAX_ITEMS=6
CHAT_HISTORY_ITEM_MAX_CHARS=700
CHAT_IMAGE_MAX_BYTES=6291456
AI_HTTP_TIMEOUT_MS=20000
AI_HTTP_MAX_RETRIES=1

# Data retention
CHAT_FEEDBACK_MAX_ITEMS=4000
CHAT_FEEDBACK_TEXT_MAX_CHARS=600
FEEDBACK_RETENTION_DAYS=14

# Recipe data limits
RECIPE_TEXT_MAX_CHARS=8000

# MySQL (optional, file fallback when missing)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=problems_co-moge-zjesc
DB_TABLE=recipes
DB_CHARSET=utf8mb3
DB_CONNECTION_LIMIT=10
